#!/usr/bin/env bash
# =============================================================================
#  UnderHost One-Domain Installer  |  https://underhost.com
#  Version: 2026.1.0
#  License: GPLv2
# =============================================================================
#
#  Usage:
#    install domain.com php          Deploy a PHP website stack
#    install domain.com wp           Deploy WordPress + PHP stack
#    install --interactive           Full guided wizard
#    install --help                  Show all flags
#
# =============================================================================

set -euo pipefail
IFS=$'\n\t'

# ---------------------------------------------------------------------------
# Resolve script directory (works when piped or sourced)
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Load core library
# ---------------------------------------------------------------------------
# shellcheck source=lib/core.sh
source "${SCRIPT_DIR}/lib/core.sh"

# ---------------------------------------------------------------------------
# Load all modules
# ---------------------------------------------------------------------------
for _mod in \
    os \
    prompts \
    packages \
    firewall \
    nginx \
    php \
    database \
    redis \
    ssl \
    ftp \
    wordpress \
    staging \
    hardening \
    optimize \
    summary \
    uninstall
do
    # shellcheck disable=SC1090
    source "${SCRIPT_DIR}/modules/${_mod}.sh"
done
unset _mod

# ---------------------------------------------------------------------------
# Global defaults (may be overridden by flags or wizard)
# ---------------------------------------------------------------------------
UNDERHOST_VERSION="2026.1.0"
INSTALL_MODE=""          # php | wp
DOMAIN=""
PHP_VERSION="8.3"
CANONICAL_WWW=false
SSL_EMAIL=""
ADMIN_EMAIL=""
SITE_ROOT=""
ENABLE_DB=true
ENABLE_REDIS=false
ENABLE_FIREWALL=true
ENABLE_FAIL2BAN=true
DB_NAME=""
DB_USER=""
DB_PASS=""
MYSQL_ROOT_PASS=""
FTP_MODE="none"          # none | sftp | ftp-tls | ftp-legacy
FTP_USER=""
FTP_PASS=""
WP_TITLE=""
WP_ADMIN_USER="admin"
WP_ADMIN_PASS=""
WP_ADMIN_EMAIL=""
WP_REDIS=false
WP_HARDEN=true
WP_AUTO_UPDATES=true
WP_STAGING=false
WP_STAGING_TYPE="subdomain"   # subdomain | subdir
STAGING_DOMAIN=""
STAGING_ROOT=""
STAGING_DB_NAME=""
STAGING_DB_USER=""
STAGING_DB_PASS=""
STAGING_HTTP_USER=""
STAGING_HTTP_PASS=""
ENABLE_PHPMYADMIN=false
ENABLE_WPCLI=true
ENABLE_COMPOSER=false
ENABLE_IMGOPT=false
CONFIGURE_SWAP=true
TUNE_SERVICES=true
BASIC_MODE=false
DRY_RUN=false
SKIP_PROMPT=false
INTERACTIVE=false
BACKUP=false
LOG_FILE="/var/log/underhost_install.log"

# ---------------------------------------------------------------------------
# Parse positional + flag arguments
# ---------------------------------------------------------------------------
_parse_args() {
    # Positional shorthand:  install domain.com php|wp
    #                        install --uninstall domain.com
    if [[ $# -ge 1 && "$1" == "--uninstall" ]]; then
        shift
        local target_domain="${1:-}"
        _ensure_root
        _init_log
        source "${SCRIPT_DIR}/modules/uninstall.sh" 2>/dev/null || true
        uninstall_domain "$target_domain"
        exit 0
    fi

    if [[ $# -ge 2 && "$1" != --* && "$1" != -* ]]; then
        DOMAIN="$1"
        case "${2,,}" in
            php) INSTALL_MODE="php" ;;
            wp|wordpress) INSTALL_MODE="wp" ;;
            *) die "Unknown mode '$2'. Use 'php' or 'wp'." ;;
        esac
        shift 2
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interactive)        INTERACTIVE=true ;;
            --basic)              BASIC_MODE=true  ;;
            --advanced)           BASIC_MODE=false ;;
            --dry-run)            DRY_RUN=true     ;;
            --force)              SKIP_PROMPT=true ;;
            --backup)             BACKUP=true      ;;
            --php-version)        PHP_VERSION="$2";   shift ;;
            --ssl-email)          SSL_EMAIL="$2";     shift ;;
            --admin-email)        ADMIN_EMAIL="$2";   shift ;;
            --domain)             DOMAIN="$2";        shift ;;
            --mode)               INSTALL_MODE="$2";  shift ;;
            --with-redis)         ENABLE_REDIS=true   ;;
            --with-db)            ENABLE_DB=true      ;;
            --no-db)              ENABLE_DB=false     ;;
            --with-staging)       WP_STAGING=true     ;;
            --with-ftp)           FTP_MODE="ftp-tls"  ;;
            --with-sftp-only)     FTP_MODE="sftp"     ;;
            --with-phpmyadmin)    ENABLE_PHPMYADMIN=true ;;
            --uninstall)
                shift
                local target_domain="${1:-$DOMAIN}"
                _ensure_root
                _init_log
                uninstall_domain "$target_domain"
                exit 0
                ;;
            --help|-h)            _show_help; exit 0  ;;
            *) die "Unknown flag: $1. Run with --help." ;;
        esac
        shift
    done
}

_show_help() {
    cat <<EOF
$(color BOLD "UnderHost One-Domain Installer v${UNDERHOST_VERSION}")
$(color CYAN "https://underhost.com")

$(color BOLD USAGE:)
  install <domain> php        Deploy a PHP website stack
  install <domain> wp         Deploy a WordPress stack
  install --interactive       Full guided installation wizard

$(color BOLD FLAGS:)
  --basic                     Wizard asks essential questions only
  --advanced                  Wizard asks everything (default)
  --dry-run                   Print what would happen, make no changes
  --force                     Skip confirmation prompts
  --backup                    Back up existing configs first
  --php-version VERSION       PHP version to install (default: 8.3)
  --ssl-email EMAIL           Email for Let's Encrypt certificates
  --admin-email EMAIL         Admin/contact email for the server
  --with-redis                Enable Redis object cache
  --with-db / --no-db         Create a database or skip
  --with-staging              Create a WordPress staging environment
  --with-ftp                  Enable FTP with TLS
  --with-sftp-only            Enable SFTP file access only
  --with-phpmyadmin           Install phpMyAdmin (security warning applies)
  --uninstall <domain>        Remove a previously installed domain deployment
  --help                      Show this help

$(color BOLD EXAMPLES:)
  install example.com php
  install example.com wp --with-redis --with-staging
  install example.com php --php-version 8.4 --no-db --ssl-email you@example.com
  install --interactive

$(color BOLD "SUPPORTED OS:)
  AlmaLinux 9/10 · Ubuntu 24.04/25.xx · Debian 12/13

EOF
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
main() {
    _ensure_root
    _init_log

    _parse_args "$@"

    # If no domain, no mode, or --interactive → run the wizard
    if [[ -z "$DOMAIN" || -z "$INSTALL_MODE" || "$INTERACTIVE" == true ]]; then
        INTERACTIVE=true
        run_wizard
    fi

    # Validate mode value (catches bad --mode flag input)
    case "$INSTALL_MODE" in
        php|wp) ;;
        *) die "Unknown install mode: '${INSTALL_MODE}'. Use 'php' or 'wp'." ;;
    esac

    # Final validation before we touch anything
    os_detect
    os_validate_support
    _validate_domain "$DOMAIN"
    _resolve_defaults

    if [[ "$DRY_RUN" == true ]]; then
        warn "DRY RUN — no changes will be made"
        _print_plan
        exit 0
    fi

    _confirm_plan

    # ------------------------------------------------------------------
    # Execute install pipeline
    # ------------------------------------------------------------------
    step "Starting UnderHost installation for ${BOLD}${DOMAIN}${RESET} [${INSTALL_MODE^^}]"

    [[ "$BACKUP" == true ]] && _backup_configs

    pkg_install_base
    pkg_install_stack

    [[ "$ENABLE_FIREWALL" == true ]] && firewall_configure
    [[ "$ENABLE_FAIL2BAN" == true ]] && hardening_fail2ban

    php_configure_pool
    nginx_configure_vhost

    [[ "$ENABLE_DB" == true ]] && db_create

    if [[ "$INSTALL_MODE" == "wp" ]]; then
        wp_install
        [[ "$WP_STAGING" == true ]] && staging_create
    fi

    [[ "$ENABLE_REDIS" == true ]] && redis_configure

    ssl_provision

    hardening_apply
    optimize_tune

    [[ "$FTP_MODE" != "none" ]] && ftp_configure

    _restart_services
    summary_print
}

# ---------------------------------------------------------------------------
# Helper: print the plan without executing
# ---------------------------------------------------------------------------
_print_plan() {
    info "Install plan:"
    echo "  Domain        : ${DOMAIN}"
    echo "  Mode          : ${INSTALL_MODE^^}"
    echo "  PHP version   : ${PHP_VERSION}"
    echo "  Database      : ${ENABLE_DB}"
    echo "  Redis         : ${ENABLE_REDIS}"
    echo "  Firewall      : ${ENABLE_FIREWALL}"
    echo "  Fail2Ban      : ${ENABLE_FAIL2BAN}"
    echo "  FTP mode      : ${FTP_MODE}"
    echo "  SSL email     : ${SSL_EMAIL:-"admin@${DOMAIN}"}"
    echo "  Staging       : ${WP_STAGING}"
    echo "  OS            : ${OS_ID} ${OS_VERSION}"
}

_confirm_plan() {
    [[ "$SKIP_PROMPT" == true ]] && return
    _print_plan
    echo
    prompt_yn "Proceed with installation?" "y" || die "Installation cancelled."
}

_resolve_defaults() {
    SITE_ROOT="${SITE_ROOT:-/var/www/${DOMAIN}}"
    SSL_EMAIL="${SSL_EMAIL:-admin@${DOMAIN}}"
    ADMIN_EMAIL="${ADMIN_EMAIL:-${SSL_EMAIL}}"
    local slug
    slug="$(echo "${DOMAIN}" | tr '.' '_' | tr -cd 'a-zA-Z0-9_' | cut -c1-32)"
    DB_NAME="${DB_NAME:-${slug}_db}"
    DB_USER="${DB_USER:-${slug}_usr}"
    DB_PASS="${DB_PASS:-$(gen_pass_db 24)}"
    MYSQL_ROOT_PASS="${MYSQL_ROOT_PASS:-$(gen_pass_db 28)}"
    WP_ADMIN_PASS="${WP_ADMIN_PASS:-$(gen_pass 20)}"
    WP_ADMIN_EMAIL="${WP_ADMIN_EMAIL:-${ADMIN_EMAIL}}"
    if [[ "$WP_STAGING" == true && "$WP_STAGING_TYPE" == "subdomain" ]]; then
        STAGING_DOMAIN="staging.${DOMAIN}"
    fi
}

_restart_services() {
    step "Restarting services"
    local svc
    for svc in nginx mariadb; do
        systemctl restart "$svc" 2>/dev/null && ok "Restarted $svc" || warn "Could not restart $svc"
    done
    # PHP-FPM: service name varies by OS
    local php_fpm_svc="php${PHP_VERSION}-fpm"
    systemctl restart "$php_fpm_svc" 2>/dev/null \
        || systemctl restart php-fpm 2>/dev/null \
        || warn "Could not restart PHP-FPM"
    [[ "$ENABLE_REDIS" == true ]] && systemctl restart redis 2>/dev/null || true
    [[ "$ENABLE_FAIL2BAN" == true ]] && systemctl restart fail2ban 2>/dev/null || true
}

_backup_configs() {
    local bdir="/root/uh_backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$bdir"
    step "Backing up existing configs to $bdir"
    for f in \
        /etc/nginx/nginx.conf \
        /etc/my.cnf /etc/my.cnf.d/server.cnf \
        /etc/mysql/mariadb.conf.d/50-server.cnf \
        /etc/fail2ban/jail.local \
        /etc/ssh/sshd_config
    do
        [[ -f "$f" ]] && cp "$f" "$bdir/" && ok "Backed up $f"
    done
    [[ -d /etc/nginx/conf.d ]] && cp -r /etc/nginx/conf.d "$bdir/nginx_conf.d" || true
    command -v mysqldump &>/dev/null \
        && mysqldump --all-databases > "$bdir/all_databases.sql" 2>/dev/null \
        && ok "Backed up all databases" || true
}

main "$@"
