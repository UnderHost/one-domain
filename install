#!/usr/bin/env bash
# =============================================================================
#  UnderHost One-Domain Installer  |  https://underhost.com
#  Version: 2026.4.0
#  License: GPL-3.0
# =============================================================================

set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_core="${SCRIPT_DIR}/lib/core.sh"
if [[ ! -f "$_core" ]]; then
    echo "[FATAL] Core library not found: ${_core}" >&2
    exit 1
fi
source "$_core"
unset _core

[[ -f /etc/underhost/defaults.conf ]] && source /etc/underhost/defaults.conf
[[ -f "${HOME}/.one-domain.conf"   ]] && source "${HOME}/.one-domain.conf"

_REQUIRED_MODULES=(
    os prompts packages firewall nginx php database redis ssl ftp
    wordpress staging hardening optimize summary uninstall
    status diagnose repair selfupdate
    backup info list audit checkdeps
)

for _mod in "${_REQUIRED_MODULES[@]}"; do
    _mod_file="${SCRIPT_DIR}/modules/${_mod}.sh"
    if [[ -f "$_mod_file" ]]; then
        source "$_mod_file"
    else
        echo "[FATAL] Required module not found: ${_mod_file}" >&2
        exit 1
    fi
done
unset _mod _mod_file _REQUIRED_MODULES

_wpcli_lib="${SCRIPT_DIR}/lib/wpcli.sh"
[[ -f "$_wpcli_lib" ]] && source "$_wpcli_lib"
unset _wpcli_lib

# ---------------------------------------------------------------------------
# Global defaults
# ---------------------------------------------------------------------------
UNDERHOST_VERSION="2026.4.0"
INSTALL_MODE=""
DOMAIN=""
PHP_VERSION="8.3"
CANONICAL_WWW=false
SSL_EMAIL=""
ADMIN_EMAIL=""
SITE_ROOT=""
ENABLE_DB=true
ENABLE_REDIS=false
ENABLE_FIREWALL=true
ENABLE_FAIL2BAN=true
ENABLE_AUTO_UPDATES=true
DB_NAME=""
DB_USER=""
DB_PASS=""
MYSQL_ROOT_PASS=""
FTP_MODE="none"
FTP_USER=""
FTP_PASS=""
WP_TITLE=""
WP_ADMIN_USER="admin"
WP_ADMIN_PASS=""
WP_ADMIN_EMAIL=""
WP_REDIS=false
WP_HARDEN=true
WP_AUTO_UPDATES=true
WP_STAGING=false
WP_STAGING_TYPE="subdomain"
STAGING_DOMAIN=""
STAGING_ROOT=""
STAGING_DB_NAME=""
STAGING_DB_USER=""
STAGING_DB_PASS=""
STAGING_HTTP_USER=""
STAGING_HTTP_PASS=""
ENABLE_PHPMYADMIN=false
ENABLE_WPCLI=true
ENABLE_COMPOSER=false
ENABLE_IMGOPT=false
CONFIGURE_SWAP=true
TUNE_SERVICES=true
BASIC_MODE=false
DRY_RUN=false
SKIP_PROMPT=false
INTERACTIVE=false
BACKUP=false
LOG_FILE="/var/log/underhost_install.log"
BACKUP_ROOT="${BACKUP_ROOT:-/var/backups/underhost}"
BACKUP_RETENTION_DAYS="${BACKUP_RETENTION_DAYS:-14}"
BACKUP_REMOTE_DEST="${BACKUP_REMOTE_DEST:-}"
BACKUP_SCHEDULE="${BACKUP_SCHEDULE:-daily}"
SUPPORTED_PHP_VERSIONS=(8.1 8.2 8.3 8.4)

# ---------------------------------------------------------------------------
_dispatch_command() {
    local cmd="${1:-}"
    cmd="${cmd#--}"
    case "$cmd" in
        status)          _ensure_root; _init_log; os_detect 2>/dev/null||true; status_domain "${2:-}"; exit 0 ;;
        diagnose)        _ensure_root; _init_log; os_detect 2>/dev/null||true; diagnose_domain "${2:-}"; exit 0 ;;
        repair)          _ensure_root; _init_log; repair_domain "${2:-}"; exit 0 ;;
        logs)
            local log_domain="${2:-}"
            [[ -z "$log_domain" ]] && die "Usage: install logs domain.com"
            local log_file="/var/log/nginx/${log_domain}.access.log"
            [[ -f "$log_file" ]] || log_file="/var/log/nginx/access.log"
            [[ -f "$log_file" ]] || die "Log file not found for: ${log_domain}"
            exec tail -f "$log_file"
            ;;
        ssl-renew-test|ssl_renew_test)
            _ensure_root; _init_log; os_detect 2>/dev/null||true
            DOMAIN="${2:-}"; [[ -z "$DOMAIN" ]] && die "Usage: install ssl-renew-test domain.com"
            ssl_renew_test "$DOMAIN"; exit 0 ;;
        info)            _init_log 2>/dev/null||true; info_show; exit 0 ;;
        list)            _ensure_root; _init_log; os_detect 2>/dev/null||true; list_domains; exit 0 ;;
        check-deps|checkdeps)  _init_log 2>/dev/null||true; os_detect 2>/dev/null||true; checkdeps_run; exit 0 ;;
        audit)           _ensure_root; _init_log; os_detect 2>/dev/null||true; audit_run "${2:-}"; exit 0 ;;
        apply)
            _ensure_root; _init_log
            DOMAIN="${2:-}"; [[ -z "$DOMAIN" ]] && die "Usage: install apply domain.com"
            _validate_domain "$DOMAIN"; os_detect; os_validate_support; _resolve_defaults; _apply_domain; exit 0 ;;
        backup)          _ensure_root; _init_log; backup_domain "${2:-}"; exit 0 ;;
        backup-auto)     _ensure_root; _init_log; backup_schedule "${2:-}"; exit 0 ;;
        restore)         _ensure_root; _init_log; backup_restore "${2:-}"; exit 0 ;;
        backup-list)     _ensure_root; _init_log; backup_list "${2:-}"; exit 0 ;;
        uninstall)       _ensure_root; _init_log; uninstall_domain "${2:-}"; exit 0 ;;
        update|self-update|selfupdate)  _ensure_root; _init_log; selfupdate_run; exit 0 ;;
        wp-reset-perms)  _ensure_root; _init_log; os_detect 2>/dev/null||true; wp_reset_perms "${2:-}"; exit 0 ;;
        wp-clone)        _ensure_root; _init_log; os_detect 2>/dev/null||true; wp_clone "${2:-}" "${3:-}"; exit 0 ;;
        wp-update-all)   _ensure_root; _init_log; os_detect 2>/dev/null||true; wp_update_all "${2:-}"; exit 0 ;;
        export-report)   _ensure_root; _init_log; os_detect 2>/dev/null||true; wp_export_report "${2:-}"; exit 0 ;;
        staging-push)    _ensure_root; _init_log; DOMAIN="${2:-}"; [[ -z "$DOMAIN" ]] && die "Usage: install staging-push domain.com"; os_detect 2>/dev/null||true; staging_push "$DOMAIN"; exit 0 ;;
        staging-pull)    _ensure_root; _init_log; DOMAIN="${2:-}"; [[ -z "$DOMAIN" ]] && die "Usage: install staging-pull domain.com"; os_detect 2>/dev/null||true; staging_pull "$DOMAIN"; exit 0 ;;
        harden|harden-only)
            _ensure_root; _init_log; os_detect; os_validate_support
            [[ -n "${2:-}" ]] && { DOMAIN="${2}"; harden_apply_domain "$DOMAIN"; }
            harden_apply_system; exit 0 ;;
        optimize)        _ensure_root; _init_log; os_detect; optimize_only "${2:-}"; exit 0 ;;
        version|--version|-V) echo "UnderHost One-Domain Installer v${UNDERHOST_VERSION}"; exit 0 ;;
        help|--help|-h)  _show_help; exit 0 ;;
        *)               return 1 ;;
    esac
}

# ---------------------------------------------------------------------------
_parse_args() {
    if [[ $# -ge 1 ]]; then
        _dispatch_command "$@" && return || true
    fi

    if [[ $# -ge 2 && "$1" != --* && "$1" != -* ]]; then
        DOMAIN="$1"
        case "${2,,}" in
            php)           INSTALL_MODE="php"; shift 2 ;;
            wp|wordpress)  INSTALL_MODE="wp";  shift 2 ;;
            *)             shift 1 ;;
        esac
    elif [[ $# -ge 1 && "$1" != --* && "$1" != -* ]]; then
        DOMAIN="$1"; shift
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interactive)     INTERACTIVE=true ;;
            --basic)           BASIC_MODE=true  ;;
            --advanced)        BASIC_MODE=false ;;
            --dry-run)         DRY_RUN=true     ;;
            --force)           SKIP_PROMPT=true ;;
            --backup)          BACKUP=true      ;;
            --php-version)     PHP_VERSION="${2:?'--php-version requires a value'}"; _validate_php_version "$PHP_VERSION"; shift ;;
            --ssl-email)       SSL_EMAIL="${2:?'--ssl-email requires a value'}"; _validate_email "$SSL_EMAIL" "--ssl-email"; shift ;;
            --admin-email)     ADMIN_EMAIL="${2:?'--admin-email requires a value'}"; _validate_email "$ADMIN_EMAIL" "--admin-email"; shift ;;
            --domain)          DOMAIN="${2:?'--domain requires a value'}"; shift ;;
            --mode)            INSTALL_MODE="${2:?'--mode requires a value'}"; shift ;;
            --site-root)       SITE_ROOT="${2:-}"; shift ;;
            --log-file)        LOG_FILE="${2:-}"; shift ;;
            --wp-title)        WP_TITLE="${2:-}"; shift ;;
            --wp-admin-user)   WP_ADMIN_USER="${2:-}"; shift ;;
            --wp-admin-email)  WP_ADMIN_EMAIL="${2:-}"; shift ;;
            --with-redis)      ENABLE_REDIS=true; WP_REDIS=true ;;
            --with-db)         ENABLE_DB=true       ;;
            --no-db)           ENABLE_DB=false      ;;
            --with-staging)    WP_STAGING=true      ;;
            --with-ftp)        FTP_MODE="ftp-tls"   ;;
            --with-sftp-only)  FTP_MODE="sftp"      ;;
            --with-phpmyadmin) ENABLE_PHPMYADMIN=true ;;
            --no-firewall)     ENABLE_FIREWALL=false  ;;
            --no-fail2ban)     ENABLE_FAIL2BAN=false  ;;
            --no-auto-updates) ENABLE_AUTO_UPDATES=false ;;
            --no-swap)         CONFIGURE_SWAP=false   ;;
            --no-tune)         TUNE_SERVICES=false    ;;
            --backup-dest)     BACKUP_REMOTE_DEST="${2:-}"; shift ;;
            --backup-retention) BACKUP_RETENTION_DAYS="${2:-14}"; shift ;;
            --version|-V)      echo "UnderHost One-Domain Installer v${UNDERHOST_VERSION}"; exit 0 ;;
            --help|-h)         _show_help; exit 0 ;;
            --)                shift; break ;;
            --*)               die "Unknown flag: $1 — run with --help to see available options" ;;
            *)                 die "Unexpected argument: $1 — run with --help to see available options" ;;
        esac
        shift
    done
}

# ---------------------------------------------------------------------------
_show_help() {
    cat <<EOF
$(color BOLD "UnderHost One-Domain Installer v${UNDERHOST_VERSION}")
$(color CYAN "https://underhost.com") | $(color DIM "GPL-3.0")

$(color BOLD "DEPLOY:")
  install <domain> php                    Deploy a plain PHP website stack
  install <domain> wp                     Deploy a WordPress + PHP stack
  install <domain> wp --with-staging      Deploy WordPress with staging
  install --interactive                   Full guided installation wizard

$(color BOLD "MAINTENANCE:")
  install status    <domain>              Quick health check
  install diagnose  <domain>              Advanced diagnostic report
  install repair    <domain>              Interactive repair wizard
  install logs      <domain>              Tail Nginx access log live
  install ssl-renew-test <domain>         Dry-run SSL renewal test
  install info                            Show server & installer environment
  install list                            List all managed domains on this server
  install check-deps                      Pre-flight connectivity & tool check
  install audit     [domain]              Security baseline audit (read-only)
  install apply     <domain>              Re-apply stack config (idempotent)

$(color BOLD "BACKUP & RESTORE:")
  install backup      <domain>            On-demand full backup (files + DB)
  install backup-auto <domain>            Install automatic scheduled backup
  install restore     <domain>            Interactive restore from backup
  install backup-list <domain>            List available backups

$(color BOLD "WORDPRESS TOOLS:")
  install wp-reset-perms <domain>         Fix broken file permissions
  install wp-clone <src.com> <dst.com>    Clone a WordPress install
  install wp-update-all  <domain>         Update WP core + all plugins + themes
  install export-report  <domain>         Generate customer summary report
  install staging-push   <domain>         Push staging -> production
  install staging-pull   <domain>         Refresh staging from production

$(color BOLD "SECURITY & PERFORMANCE:")
  install harden   [domain]               Apply full security hardening
  install optimize [domain]               Apply performance tuning only

$(color BOLD "MANAGEMENT:")
  install uninstall <domain>              Remove a domain deployment cleanly
  install update                          Update installer from GitHub
  install version                         Show installer version

$(color BOLD "KEY FLAGS:")
  --basic / --advanced       Wizard depth
  --dry-run                  Show plan, make no changes
  --force                    Skip confirmation prompts
  --php-version VERSION      8.1 / 8.2 / 8.3 / 8.4  (default: 8.3)
  --ssl-email EMAIL          Email for Let's Encrypt
  --with-redis               Enable Redis object cache
  --with-staging             WordPress staging environment
  --with-ftp / --with-sftp-only  File access method
  --no-auto-updates          Skip automatic OS security updates
  --backup-dest DEST         rsync:user@host:/path or rclone:remote:bucket
  --backup-retention DAYS    Days to keep backups (default: 14)

$(color BOLD "SUPPORTED OS:")
  Ubuntu 24.04 / 25.xx  |  Debian 12 / 13  |  AlmaLinux 9 / 10

$(color BOLD "CONFIG FILE (optional):")
  /etc/underhost/defaults.conf  or  ~/.one-domain.conf
  Example: PHP_VERSION=8.4  SSL_EMAIL=ops@example.com  BACKUP_RETENTION_DAYS=30

$(color DIM "Full docs: https://github.com/UnderHost/one-domain")
EOF
}

# ---------------------------------------------------------------------------
_validate_php_version() {
    local ver="$1"
    for supported in "${SUPPORTED_PHP_VERSIONS[@]}"; do
        [[ "$ver" == "$supported" ]] && return 0
    done
    die "Unsupported PHP version: ${ver}. Supported: ${SUPPORTED_PHP_VERSIONS[*]}"
}

_apply_domain() {
    step "Re-applying stack configuration for ${DOMAIN}"
    warn "This will overwrite Nginx vhost and PHP-FPM pool for ${DOMAIN}."
    prompt_yn "Proceed?" "y" || die "Apply cancelled."
    php_configure_pool
    nginx_configure_vhost
    hardening_apply
    [[ "$TUNE_SERVICES" == true ]] && optimize_tune
    _restart_services
    ok "Stack configuration re-applied for ${DOMAIN}"
}

# ---------------------------------------------------------------------------
main() {
    _ensure_root
    _init_log
    _parse_args "$@"

    if [[ -z "$DOMAIN" || -z "$INSTALL_MODE" || "$INTERACTIVE" == true ]]; then
        INTERACTIVE=true
        run_wizard
    fi

    case "$INSTALL_MODE" in
        php|wp) ;;
        *) die "Unknown install mode: '${INSTALL_MODE}'. Use 'php' or 'wp'." ;;
    esac

    _validate_domain "$DOMAIN"
    [[ -n "$PHP_VERSION" ]] && _validate_php_version "$PHP_VERSION"
    os_detect; os_validate_support; os_preflight
    _resolve_defaults

    if [[ "$DRY_RUN" == true ]]; then
        warn "DRY RUN — no changes will be made"
        _print_plan; exit 0
    fi

    _confirm_plan

    step "Starting UnderHost installation for ${BOLD}${DOMAIN}${RESET} [${INSTALL_MODE^^}]"
    log_msg "Install started: domain=${DOMAIN} mode=${INSTALL_MODE} php=${PHP_VERSION} os=${OS_ID:-unknown} ${OS_VERSION:-} v${UNDERHOST_VERSION}"

    [[ "$BACKUP" == true ]] && _backup_configs

    pkg_install_base
    pkg_install_stack

    [[ "$ENABLE_FIREWALL"  == true ]] && firewall_configure
    [[ "$ENABLE_FAIL2BAN"  == true ]] && hardening_fail2ban

    php_configure_pool
    nginx_configure_vhost

    [[ "$ENABLE_DB"    == true ]] && db_create
    [[ "$ENABLE_REDIS" == true ]] && redis_configure

    if [[ "$INSTALL_MODE" == "wp" ]]; then
        wp_install
        [[ "$WP_STAGING" == true ]] && staging_create
    fi

    ssl_provision
    hardening_apply
    [[ "$TUNE_SERVICES" == true ]] && optimize_tune
    [[ "$FTP_MODE" != "none" ]] && ftp_configure

    _restart_services
    summary_print
    log_msg "Install completed successfully: domain=${DOMAIN}"
}

# ---------------------------------------------------------------------------
_print_plan() {
    info "Install plan:"
    printf "  %-24s : %s\n" "Domain"          "${DOMAIN}"
    printf "  %-24s : %s\n" "Mode"            "${INSTALL_MODE^^}"
    printf "  %-24s : %s\n" "PHP version"     "${PHP_VERSION}"
    printf "  %-24s : %s\n" "Document root"   "${SITE_ROOT:-/var/www/${DOMAIN}}"
    printf "  %-24s : %s\n" "Database"        "${ENABLE_DB}"
    printf "  %-24s : %s\n" "Redis"           "${ENABLE_REDIS}"
    printf "  %-24s : %s\n" "Firewall"        "${ENABLE_FIREWALL}"
    printf "  %-24s : %s\n" "Fail2Ban"        "${ENABLE_FAIL2BAN}"
    printf "  %-24s : %s\n" "Auto OS updates" "${ENABLE_AUTO_UPDATES}"
    printf "  %-24s : %s\n" "FTP mode"        "${FTP_MODE}"
    printf "  %-24s : %s\n" "SSL email"       "${SSL_EMAIL:-admin@${DOMAIN}}"
    printf "  %-24s : %s\n" "Staging"         "${WP_STAGING}"
    printf "  %-24s : %s\n" "Performance"     "${TUNE_SERVICES}"
    printf "  %-24s : %s\n" "OS"              "${OS_ID:-unknown} ${OS_VERSION:-}"
    printf "  %-24s : %s\n" "Installer"       "v${UNDERHOST_VERSION}"
}

_confirm_plan() {
    [[ "$SKIP_PROMPT" == true ]] && return
    echo; _print_plan; echo
    prompt_yn "Proceed with installation?" "y" || die "Installation cancelled by user."
}

_resolve_defaults() {
    SITE_ROOT="${SITE_ROOT:-/var/www/${DOMAIN}}"
    SSL_EMAIL="${SSL_EMAIL:-admin@${DOMAIN}}"
    ADMIN_EMAIL="${ADMIN_EMAIL:-${SSL_EMAIL}}"
    local slug
    slug="$(echo "${DOMAIN}" | tr '.' '_' | tr -cd 'a-zA-Z0-9_' | cut -c1-32)"
    DB_NAME="${DB_NAME:-${slug}_db}"
    DB_USER="${DB_USER:-${slug}_usr}"
    DB_PASS="${DB_PASS:-$(gen_pass_db 24)}"
    MYSQL_ROOT_PASS="${MYSQL_ROOT_PASS:-$(gen_pass_db 28)}"
    WP_ADMIN_PASS="${WP_ADMIN_PASS:-$(gen_pass 20)}"
    WP_ADMIN_EMAIL="${WP_ADMIN_EMAIL:-${ADMIN_EMAIL}}"
    WP_TITLE="${WP_TITLE:-${DOMAIN}}"
    [[ "$WP_STAGING" == true && "$WP_STAGING_TYPE" == "subdomain" ]] \
        && STAGING_DOMAIN="${STAGING_DOMAIN:-staging.${DOMAIN}}"
    STAGING_DB_NAME="${STAGING_DB_NAME:-${slug}_stg_db}"
    STAGING_DB_USER="${STAGING_DB_USER:-${slug}_stg_usr}"
    STAGING_DB_PASS="${STAGING_DB_PASS:-$(gen_pass_db 24)}"
    STAGING_HTTP_USER="${STAGING_HTTP_USER:-staging}"
    STAGING_HTTP_PASS="${STAGING_HTTP_PASS:-$(gen_pass 16)}"
    FTP_USER="${FTP_USER:-${slug}_ftp}"
    FTP_PASS="${FTP_PASS:-$(gen_pass 20)}"
}

_restart_services() {
    step "Restarting services"
    for svc in nginx mariadb; do
        systemctl restart "$svc" 2>/dev/null \
            && ok "Restarted ${svc}" \
            || warn "Could not restart ${svc}"
    done
    local php_fpm_svc
    php_fpm_svc="$(os_php_fpm_service 2>/dev/null || true)"
    [[ -z "$php_fpm_svc" ]] && {
        [[ "${OS_FAMILY:-}" == "debian" ]] \
            && php_fpm_svc="php${PHP_VERSION}-fpm" \
            || php_fpm_svc="php-fpm"
    }
    systemctl restart "$php_fpm_svc" 2>/dev/null \
        && ok "Restarted ${php_fpm_svc}" \
        || warn "Could not restart PHP-FPM (${php_fpm_svc})"
    [[ "$ENABLE_REDIS"    == true ]] && { systemctl restart redis-server 2>/dev/null || systemctl restart redis 2>/dev/null || true; }
    [[ "$ENABLE_FAIL2BAN" == true ]] && { systemctl restart fail2ban 2>/dev/null || true; }
}

_backup_configs() {
    local bdir="/root/uh_backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$bdir"; chmod 700 "$bdir"
    step "Backing up existing configs to ${bdir}"
    local f
    for f in /etc/nginx/nginx.conf /etc/my.cnf /etc/my.cnf.d/server.cnf \
              /etc/mysql/mariadb.conf.d/50-server.cnf /etc/fail2ban/jail.local /etc/ssh/sshd_config; do
        [[ -f "$f" ]] && cp "$f" "$bdir/" && ok "Backed up ${f}"
    done
    [[ -d /etc/nginx/conf.d ]] && cp -r /etc/nginx/conf.d "$bdir/nginx_conf.d" 2>/dev/null || true
    if command -v mysqldump &>/dev/null && [[ -f /root/.my.cnf ]]; then
        mysqldump --defaults-extra-file=/root/.my.cnf --all-databases \
            > "${bdir}/all_databases.sql" 2>/dev/null \
            && chmod 600 "${bdir}/all_databases.sql" \
            && ok "Backed up all databases"
    fi
    ok "Backup saved to: ${bdir}"
}

main "$@"
