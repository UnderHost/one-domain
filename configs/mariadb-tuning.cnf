# =============================================================================
# UnderHost MariaDB/MySQL Tuning Reference
#
# For Ubuntu/Debian: /etc/mysql/mariadb.conf.d/uh-tuning.cnf
# For AlmaLinux:     /etc/my.cnf.d/uh-tuning.cnf
#
# After editing: systemctl restart mariadb
# Check status:  mysqladmin -u root -p status
# =============================================================================

[mysqld]

# ─── InnoDB Buffer Pool ──────────────────────────────────────────────────────
# Most important tuning value. Set to 50-70% of available RAM.
# Single site server with 1 GB RAM  → 256M
# Single site server with 2 GB RAM  → 512M
# Single site server with 4 GB RAM  → 1G
# Single site server with 8 GB RAM  → 2G
innodb_buffer_pool_size = 256M

# Number of buffer pool instances. Use 1 per GB of buffer pool, up to 8.
# innodb_buffer_pool_instances = 1

# ─── InnoDB Log ──────────────────────────────────────────────────────────────
innodb_log_file_size    = 64M
innodb_log_buffer_size  = 16M

# ─── InnoDB Flush ────────────────────────────────────────────────────────────
# 1 = safest (ACID) but slowest   — use for financial/critical data
# 2 = good balance                 — recommended for web applications
# 0 = fastest but risky on crash  — not recommended for production
innodb_flush_log_at_trx_commit = 2

# O_DIRECT avoids double-buffering with OS page cache (Linux only)
innodb_flush_method = O_DIRECT

# ─── Connections ─────────────────────────────────────────────────────────────
# Max simultaneous connections. Each uses ~1-3MB RAM.
# 100 is fine for single-site. Monitor with: SHOW STATUS LIKE 'Max_used_connections';
max_connections     = 100
max_connect_errors  = 1000000

# ─── Query Cache ─────────────────────────────────────────────────────────────
# Disabled — query cache is a global mutex bottleneck on writes.
# Use Redis/Memcached for application-level caching instead.
query_cache_type  = 0
query_cache_size  = 0

# ─── Slow Query Log ──────────────────────────────────────────────────────────
# Essential for identifying performance problems.
slow_query_log       = 1
slow_query_log_file  = /var/log/mysql/slow.log
long_query_time      = 2
log_queries_not_using_indexes = 0

# ─── Temporary Tables ────────────────────────────────────────────────────────
# Increase if slow query log shows many temp table disk writes.
tmp_table_size       = 64M
max_heap_table_size  = 64M

# ─── Thread Cache ────────────────────────────────────────────────────────────
thread_cache_size = 16

# ─── Character Set ───────────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ─── Binary Log ──────────────────────────────────────────────────────────────
# Enable only if you need replication or point-in-time recovery.
# skip-log-bin

# ─── Security ────────────────────────────────────────────────────────────────
# Prevent LOAD DATA INFILE from reading arbitrary local files
local-infile = 0

# ─── Tuning Cheatsheet ───────────────────────────────────────────────────────
# RAM    | innodb_buffer_pool | max_connections | tmp_table_size
# 512 MB |        128M        |       50        |      32M
# 1 GB   |        256M        |      100        |      64M
# 2 GB   |        512M        |      150        |      64M
# 4 GB   |         1G         |      200        |     128M
# 8 GB   |         2G         |      300        |     256M
#
# Useful queries:
#   SHOW ENGINE INNODB STATUS\G
#   SHOW GLOBAL STATUS LIKE 'Innodb_buffer_pool%';
#   SHOW GLOBAL VARIABLES LIKE 'innodb_buffer_pool_size';
